{
	"name": "@react-native-pulse-debugger/root",
	"packageManager": "yarn@4.8.1",
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"lint": "eslint . --ext .ts,.tsx",
		"lint:fix": "eslint . --ext .ts,.tsx --fix",
		"format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
		"format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
		"debugger:dev": "yarn workspace @react-native-pulse-debugger/tool dev",
		"debugger:build": "yarn workspace @react-native-pulse-debugger/tool build",
		"types:watch": "yarn workspace @react-native-pulse-debugger/types watch",
		"dev": "yarn debugger:dev",
		"app-example:start": "cd packages/lib/example && yarn start",
		"test": "yarn workspaces foreach -A -pt run test"
	},
	"devDependencies": {
		"@changesets/cli": "^2.29.4",
		"@testing-library/jest-dom": "^6.6.3",
		"@typescript-eslint/eslint-plugin": "^7.0.0",
		"@typescript-eslint/parser": "^7.0.0",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-react": "^7.33.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"eslint-plugin-react-refresh": "^0.4.5",
		"globals": "^14.0.0",
		"prettier": "^3.2.5",
		"typescript": "^5.3.0",
		"typescript-eslint": "^7.0.0"
	},
	"dependencies": {
		"electron-store": "^10.0.1"
	}
}
